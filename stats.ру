from storage import load_books

def get_average_rating():
    books = load_books()
    if not books: return 0.0
    return round(sum(b.rating for b in books) / len(books), 2)

def get_author_stats():
    books = load_books()
    stats = {}
    for b in books:
        stats[b.author] = stats.get(b.author, 0) + 1
    return stats
