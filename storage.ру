import json
import os
from models import Book

DATA_FILE = "books.json"

def load_books():
    if not os.path.exists(DATA_FILE):
        return []
    with open(DATA_FILE, "r", encoding="utf-8") as f:
        data = json.load(f)
    return [Book.from_dict(item) for item in data]

def save_books(books):
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump([b.to_dict() for b in books], f, ensure_ascii=False, indent=2)

def add_book(author, title, rating, read_date):
    books = load_books()
    for b in books:
        if b.author.lower() == author.lower() and b.title.lower() == title.lower():
            return False, "Такая книга уже есть!"
    
    new_book = Book(author=author, title=title, rating=rating, read_date=read_date)
    books.append(new_book)
    save_books(books)
    return True, "Книга добавлена!"

def delete_book(title):
    books = load_books()
    start_len = len(books)
    books = [b for b in books if b.title.lower() != title.lower()]
    if len(books) == start_len:
        return False, "Книга не найдена"
    save_books(books)
    return True, "Книга удалена"
