from storage import add_book, delete_book
from stats import get_average_rating, get_author_stats

def show_menu():
    print("\n=== Трекер книг ===")
    print("1. Добавить книгу")
    print("2. Показать все книги")
    print("3. Средняя оценка")
    print("4. Статистика по авторам")
    print("5. Удалить книгу")
    print("6. Выход")

def main():
    while True:
        show_menu()
        choice = input("Выбор: ").strip()

        if choice == "1":
            author = input("Автор: ")
            title = input("Название: ")
            try:
                rating = int(input("Оценка (1-5): "))
                if not 1 <= rating <= 5:
                    print("Оценка должна быть от 1 до 5")
                    continue
            except ValueError:
                print("Ошибка: оценка должна быть числом")
                continue
            date = input("Дата (YYYY-MM-DD): ")
            ok, msg = add_book(author, title, rating, date)
            print(msg)

        elif choice == "2":
            from storage import load_books
            books = load_books()
            if not books:
                print("Список пуст")
            else:
                for i, b in enumerate(books, 1):
                    print(f"{i}. {b.title} ({b.author}) - {b.rating}/5")

        elif choice == "3":
            avg = get_average_rating()
            print(f"Средняя оценка: {avg}")

        elif choice == "4":
            stats = get_author_stats()
            for author, count in stats.items():
                print(f"{author}: {count} книг")

        elif choice == "5":
            title = input("Название для удаления: ")
            ok, msg = delete_book(title)
            print(msg)

        elif choice == "6":
            print("Пока!")
            break
        else:
            print("Неверная команда")

if __name__ == "__main__":
    main()
